# StudentMate Flutter Project - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# APPLICATION INFO
# ============================================================================
APP_NAME=StudentMate
APP_VERSION=1.0.0
APP_DESCRIPTION=A comprehensive Flutter-based academic productivity application

# ============================================================================
# MONGODB CONFIGURATION
# ============================================================================
# For Android Emulator: mongodb://10.0.2.2:27017/studentmate
# For Physical Android Device: mongodb://YOUR_PC_LAN_IP:27017/studentmate
# For Windows/Web Dev: mongodb://localhost:27017/studentmate
# For Web Deployment: mongodb+srv://username:password@cluster.mongodb.net/studentmate

MONGODB_URI=mongodb://localhost:27017/studentmate
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=studentmate

# ============================================================================
# DATABASE CONFIGURATION - HIVE LOCAL STORAGE
# ============================================================================
# Hive stores data locally on the device in Documents/StudentMate/ directory
# Data persists across app sessions

# Hive Box Names (Local Storage)
HIVE_USER_BOX=user_box
HIVE_ATTENDANCE_BOX=attendance_box
HIVE_GRADES_BOX=grades_box
HIVE_TIMETABLE_BOX=timetable_box
HIVE_THEME_BOX=theme_box
HIVE_ANNOUNCEMENT_BOX=announcement_box
HIVE_CLUB_EVENT_BOX=club_event_box
HIVE_CACHE_BOX=offline_cache_box

# ============================================================================
# APP CONSTANTS
# ============================================================================
MIN_ATTENDANCE_PERCENTAGE=75.0
SEMESTER_COUNT=8

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_MONGODB=true
ENABLE_HIVE_LOCAL_STORAGE=true
ENABLE_ATTENDANCE_TRACKING=true
ENABLE_GRADE_TRACKING=true
ENABLE_TIMETABLE=true
ENABLE_CLUB_EVENTS=true
ENABLE_ANNOUNCEMENTS=true
ENABLE_NOTIFICATIONS=false
ENABLE_DARK_MODE=true

# ============================================================================
# FIREBASE CONFIGURATION (Currently Disabled on Windows)
# ============================================================================
# Firebase is disabled for Windows desktop builds due to CMake compilation
# Uncomment and configure if building for Android/iOS/Web

# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_API_KEY=your-api-key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# FIREBASE_APP_ID=your-app-id

# ============================================================================
# DATA STRUCTURE - COLLECTIONS SCHEMA
# ============================================================================
# MongoDB Collections:
#
# 1. users
#    - email (unique index)
#    - password
#    - userType (student|faculty|admin)
#    - branch
#    - section
#    - name
#    - rollNo
#    - createdAt
#
# 2. attendance
#    - userId (indexed with subject)
#    - subject
#    - presentDays
#    - totalDays
#    - percentage
#    - semester
#    - academicYear
#    - date
#
# 3. grades
#    - userId (indexed with semester)
#    - subject
#    - marks
#    - credits
#    - semester
#    - grade
#    - academicYear
#
# 4. timetable
#    - branch
#    - section
#    - scheduleData (JSON)
#    - academicYear
#
# 5. announcements
#    - announcementType (class|subject|general)
#    - branch
#    - section
#    - subject
#    - title
#    - content
#    - authorId
#    - createdAt (indexed)
#    - isActive
#    - priority
#
# 6. club_events
#    - eventName
#    - eventDate (indexed)
#    - eventDescription
#    - location
#    - organizer
#    - createdAt
#    - status
#
# 7. calendar_events
#    - eventName
#    - eventDate (indexed)
#    - eventDescription
#    - createdAt
#
# 8. notices
#    - noticeTitle
#    - noticeContent
#    - noticePriority
#    - createdAt (indexed)
#    - createdBy

# ============================================================================
# LOCAL DATA STORAGE PATHS
# ============================================================================
# On Windows: %APPDATA%\StudentMate\
# On Android: /data/data/com.example.student_mate/
# On iOS: User Documents Folder
#
# Hive data files are stored in:
# - user_box.hive
# - attendance_box.hive
# - grades_box.hive
# - timetable_box.hive
# - theme_box.hive
# - announcement_box.hive
# - club_event_box.hive
# - offline_cache_box.hive

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=debug
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=false

# ============================================================================
# API ENDPOINTS
# ============================================================================
API_BASE_URL=http://localhost:27017
API_TIMEOUT_SECONDS=30
API_RETRY_COUNT=3

# ============================================================================
# THEME CONFIGURATION
# ============================================================================
DEFAULT_THEME_MODE=light
PRIMARY_COLOR=#1976D2
ACCENT_COLOR=#FF5722

# ============================================================================
# NOTIFICATION CONFIGURATION (Future Implementation)
# ============================================================================
# FCM_SERVER_KEY=your-fcm-server-key
# NOTIFICATION_ENABLED_BY_DEFAULT=true
# NOTIFICATION_SOUND=true
# NOTIFICATION_VIBRATION=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Note: Sensitive data should use platform-specific secure storage
ENABLE_BIOMETRIC_AUTH=false
PASSWORD_MIN_LENGTH=6
SESSION_TIMEOUT_MINUTES=30

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
BUILD_FLAVOR=development
BUILD_NUMBER=1
BUILD_VERSION=1.0.0+1

# ============================================================================
# KOTLIN BUILD CONFIGURATION (Android)
# ============================================================================
# For Windows with Kotlin incremental cache issues:
KOTLIN_INCREMENTAL=false
KOTLIN_COMPILER_EXECUTION_STRATEGY=in-process

# ============================================================================
# DEEP LINKING CONFIGURATION
# ============================================================================
# Deep linking is currently disabled for Windows desktop builds
# DEEP_LINK_DOMAIN=studentmate.app
# DEEP_LINK_ENABLED=false
