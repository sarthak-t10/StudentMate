{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Flutter: Build APK",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"apk",
				"--release"
			],
			"group": "build"
		},
		{
			"label": "Flutter: Run Dev",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Flutter: Analyze",
			"type": "shell",
			"command": "flutter",
			"args": [
				"analyze"
			],
			"group": "test"
		}
	]
}